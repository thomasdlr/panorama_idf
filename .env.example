# ── Dokploy / domaines ────────────────────────────────────────────────
# Informatif : les domaines réels sont mappés dans l'UI Dokploy (service → domain).
# Cette variable est juste injectée à Metabase pour qu'il connaisse son URL publique.
METABASE_SITE_URL=https://metabase.tdelard.me

# ── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_DB=panorama_idf
POSTGRES_USER=metabase
# ← génère un mot de passe fort : openssl rand -base64 24
POSTGRES_PASSWORD=REMPLACE_MOI

# ── Admin Metabase ────────────────────────────────────────────────────
MB_ADMIN_EMAIL=admin@tdelard.me
MB_ADMIN_PASSWORD=REMPLACE_MOI_AUSSI
