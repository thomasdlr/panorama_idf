# ─────────────────────────────────────────────────────────────────────
# .env.example — documentation de toutes les variables surchargeables.
#
# Philosophie :
#   - docker-compose.yml contient des defaults sûrs pour le dev local.
#     → Tu peux démarrer sans `.env` ; tout marche avec POSTGRES=metabase/metabase,
#       ADMIN=admin/dev-change-me, Umami désactivé, etc.
#   - `.env` (local) = surcharges ponctuelles, quasi toujours vide.
#   - En prod (Dokploy) : on SET ces variables dans l'UI Dokploy ("Environment"),
#     pas dans un fichier .env commité. Le .env local n'est jamais déployé.
#
# Copie ce fichier en `.env` seulement si tu as besoin d'override.
# ─────────────────────────────────────────────────────────────────────

# ── PROD UNIQUEMENT (Dokploy env) ─────────────────────────────────────
# Ne pas mettre en .env local : en local, tout tourne sur localhost:3000.

# URL publique du dashboard Metabase (ce que Metabase lui-même renvoie
# dans ses emails, liens de partage, etc.). En dev : http://localhost:3000.
METABASE_SITE_URL=https://metabase.tdelard.me

# URL du dashboard public, cible du bouton « Projet en vedette » de la landing.
# Prod : https://metabase.tdelard.me/public/dashboard/<uuid>
# Dev  : http://localhost:3000/dashboard/2 (valeur par défaut, laisser vide en local)
DASHBOARD_URL=https://metabase.tdelard.me/public/dashboard/<UUID>

# Analytics Umami cloud (https://cloud.umami.is).
# ⚠️  À NE PAS mettre en .env local, sinon les visites dev polluent les stats prod.
UMAMI_WEBSITE_ID=

# ── SECRETS (prod surtout) ────────────────────────────────────────────
# En dev : laisser vide, les defaults du compose suffisent (metabase / dev-change-me).
# En prod : `openssl rand -base64 24` pour générer des valeurs fortes.

POSTGRES_DB=panorama_idf
POSTGRES_USER=metabase
POSTGRES_PASSWORD=

MB_ADMIN_EMAIL=admin@tdelard.me
MB_ADMIN_PASSWORD=

# Page admin (admin.tdelard.me) protégée par basic auth nginx.
ADMIN_USER=admin
ADMIN_PASSWORD=
