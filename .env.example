# Domaine pointé vers ton VPS (enregistrement DNS A)
DOMAIN=panorama-idf.fr

# Email pour Let's Encrypt (certificats HTTPS)
EMAIL=your.email@gmail.com

# PostgreSQL
POSTGRES_DB=panorama_idf
POSTGRES_USER=metabase
# ← génère un mot de passe fort : openssl rand -base64 24
POSTGRES_PASSWORD=REMPLACE_MOI

# Admin Metabase
MB_ADMIN_EMAIL=admin@panorama-idf.fr
MB_ADMIN_PASSWORD=REMPLACE_MOI_AUSSI
